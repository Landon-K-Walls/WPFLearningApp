<Window x:Class="WPFLearningApp.Windows.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFLearningApp.Windows"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Button 
                x:Name="UploadButton"
                Click="UploadButton_Click">
                Choose a file to upload
            </Button>
        </StackPanel>
        <ComboBox x:Name="ExampleComboBox" Grid.Row="2" Width="150" IsReadOnly="false" IsEditable="True" SelectionChanged="ExampleComboBox_SelectionChanged"/>
        <Expander Grid.Row="3" IsExpanded="false">
            <StackPanel>
                <Grid>
                    <TextBlock>This is a textblock inside an expander</TextBlock>
                </Grid>
            </StackPanel>
        </Expander>
    </Grid>
</Window>
